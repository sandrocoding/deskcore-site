---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<PageLayout
  title="Blog — DeskCore"
  description="Articoli, guide e risorse per MSP italiani."
>
  <section class="section">
    <div class="container">
      <div class="hero-text" style="text-align:center; margin-bottom:3rem;">
        <h1>Blog</h1>
        <p class="hero-subtitle">
          Articoli, guide e risorse per gestire al meglio il tuo MSP
        </p>
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toLocaleDateString('it-IT', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
            slug={post.id}
            tags={post.data.tags}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
