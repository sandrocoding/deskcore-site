---
import PageLayout from '../layouts/PageLayout.astro';

const screenshots = [
  "Dashboard principale",
  "Gestione Ticket",
  "Rapportini di Intervento",
  "Pipeline Commerciale",
  "Portale Cliente",
  "AI Copilot"
];
---

<PageLayout
  title="Demo — DeskCore"
  description="Guarda DeskCore in azione. Richiedi una demo personalizzata per il tuo MSP."
>
  <!-- Hero -->
  <section class="section demo-hero">
    <div class="container">
      <div class="demo-hero__content fade-up">
        <h1 class="demo-hero__title">Guarda DeskCore in azione</h1>
        <p class="demo-hero__subtitle">
          Esplora le schermate principali e richiedi una demo personalizzata per il tuo MSP.
        </p>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="section demo-screenshots">
    <div class="container">
      <div class="screenshots-grid fade-up">
        {screenshots.map((label) => (
          <div class="screenshot-placeholder">
            <span class="screenshot-label">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Demo Form -->
  <section class="section demo-form-section" id="richiedi-demo">
    <div class="container">
      <div class="demo-form-wrapper fade-up">
        <h2 class="demo-form__title">Richiedi una demo personalizzata</h2>
        <p class="demo-form__subtitle">
          Compila il form e ti contatteremo entro 24 ore per organizzare una demo su misura.
        </p>

        <form class="demo-form" id="demo-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="demo-name">Nome e Cognome</label>
            <input class="form-input" type="text" id="demo-name" name="nome" required placeholder="Mario Rossi" />
          </div>

          <div class="form-group">
            <label class="form-label" for="demo-email">Email</label>
            <input class="form-input" type="email" id="demo-email" name="email" required placeholder="mario@azienda.it" />
          </div>

          <div class="form-group">
            <label class="form-label" for="demo-company">Azienda</label>
            <input class="form-input" type="text" id="demo-company" name="azienda" required placeholder="Nome azienda" />
          </div>

          <div class="form-group">
            <label class="form-label" for="demo-tecnici">Numero tecnici</label>
            <select class="form-input form-select" id="demo-tecnici" name="tecnici" required>
              <option value="" disabled selected>Seleziona...</option>
              <option value="1-3">1-3</option>
              <option value="4-10">4-10</option>
              <option value="11-25">11-25</option>
              <option value="25+">25+</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="demo-message">Messaggio</label>
            <textarea class="form-input form-textarea" id="demo-message" name="messaggio" rows="4" placeholder="Raccontaci le tue esigenze..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary demo-form__submit">Richiedi demo</button>
        </form>

        <!-- Success message (hidden by default) -->
        <div class="demo-success" id="demo-success" hidden>
          <div class="demo-success__icon">✓</div>
          <h3 class="demo-success__title">Richiesta inviata!</h3>
          <p class="demo-success__text">
            Grazie per il tuo interesse. Ti contatteremo entro 24 ore per organizzare la demo.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('demo-form') as HTMLFormElement;
    const success = document.getElementById('demo-success') as HTMLElement;

    if (form && success) {
      // Clear error on input
      form.querySelectorAll('.form-input').forEach((input) => {
        input.addEventListener('input', () => {
          input.classList.remove('form-input--error');
          input.removeAttribute('aria-invalid');
        });
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const inputs = form.querySelectorAll('[required]') as NodeListOf<HTMLInputElement>;
        let valid = true;
        let firstInvalid: HTMLInputElement | null = null;

        inputs.forEach((input) => {
          if (!input.value.trim() || (input.type === 'email' && !input.value.includes('@'))) {
            valid = false;
            input.classList.add('form-input--error');
            input.setAttribute('aria-invalid', 'true');
            if (!firstInvalid) firstInvalid = input;
          } else {
            input.classList.remove('form-input--error');
            input.removeAttribute('aria-invalid');
          }
        });

        if (!valid) {
          firstInvalid?.focus();
          return;
        }

        form.hidden = true;
        success.hidden = false;
      });
    }
  });
</script>

<style>
  /* Hero */
  .demo-hero {
    text-align: center;
    padding-bottom: 1rem;
  }

  .demo-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .demo-hero__subtitle {
    font-size: 1.125rem;
    color: var(--gray-600);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* Screenshots Grid */
  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .screenshot-placeholder {
    aspect-ratio: 16 / 9;
    background: var(--gray-200);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed var(--gray-300);
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .screenshot-placeholder:hover {
    border-color: var(--accent);
    background: var(--gray-100);
  }

  .screenshot-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--gray-400);
    text-align: center;
    padding: 1rem;
  }

  /* Form Section */
  .demo-form-wrapper {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .demo-form__title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .demo-form__subtitle {
    font-size: 1rem;
    color: var(--gray-600);
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .demo-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
  }

  .form-input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    color: var(--ink);
    background: var(--paper);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  .form-input--error {
    border-color: #ef4444;
  }

  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%239ca3af' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .demo-form__submit {
    align-self: flex-start;
    margin-top: 0.5rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* Success */
  .demo-success {
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .demo-success__icon {
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--green);
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }

  .demo-success__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .demo-success__text {
    font-size: 1rem;
    color: var(--gray-600);
    line-height: 1.6;
    max-width: 400px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .screenshots-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .screenshots-grid {
      grid-template-columns: 1fr;
    }

    .demo-form__title {
      font-size: 1.5rem;
    }

    .demo-form__submit {
      width: 100%;
    }
  }
</style>
