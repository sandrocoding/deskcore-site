---
import PageLayout from '../layouts/PageLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';

const categories = [
  {
    icon: "🔧",
    name: "Gestione Operativa",
    description: "Tutto il necessario per gestire l'operativita quotidiana del tuo MSP.",
    features: [
      { icon: "🎫", title: "Ticketing + SLA", description: "Smart assignment, Kanban, escalation automatica, merge ticket, notifiche real-time" },
      { icon: "📋", title: "Rapportini", description: "5 template PDF, firma cliente digitale, calcolo trasferte, timer, AI, workflow approvazione" },
      { icon: "🖥️", title: "Asset Management", description: "Vista ad albero, cronologia interventi, QR code, monitoring HTTP/ping, wiki aziendale" },
      { icon: "📅", title: "Calendario Tecnici", description: "Vista per risorsa, drag&drop, Gantt risorse, input vocale, conflitti automatici" },
      { icon: "📊", title: "Progetti e Commesse", description: "Kanban, burndown chart, Gantt, sub-task, budget vs actual, collaboratori" },
    ]
  },
  {
    icon: "💼",
    name: "Commerciale & CRM",
    description: "Pipeline, preventivi e contratti per far crescere il tuo business.",
    features: [
      { icon: "📈", title: "Pipeline Commerciale", description: "Lead, opportunita, conversione, forecast pesato, performance per commerciale" },
      { icon: "📝", title: "Preventivi Intelligenti", description: "Wizard 3 step, firma digitale, suggerimenti AI prodotti correlati, template editor" },
      { icon: "📄", title: "Contratti MSP", description: "7 template predefiniti, monte ore con barre progresso, residui granulari, PDF pro" },
      { icon: "🎯", title: "Campagne", description: "Kanban fasi, KPI target vs actual, 6 tipi campagna, budget e obiettivi" },
      { icon: "🔗", title: "Cross-Selling Matrix", description: "Griglia clienti x servizi, tasso penetrazione, navigazione diretta" },
    ]
  },
  {
    icon: "💰",
    name: "Fatturazione & Finance",
    description: "Dalla fatturazione automatica all'analisi finanziaria avanzata.",
    features: [
      { icon: "🧾", title: "Fatture in Cloud", description: "Integrazione nativa bidirezionale, import clienti, righe fatturabili, bozze" },
      { icon: "🔄", title: "Canoni e Noleggi", description: "Ricorrenza configurabile, MRR/ARR tracking, fatturazione automatica cron" },
      { icon: "💹", title: "Analisi Costi Orari", description: "Margine per tecnico/cliente/intervento, tariffe vendita con markup" },
      { icon: "📉", title: "Revenue Intelligence", description: "MRR, churn prediction AI, LTV per cliente, forecast 3/6/12 mesi" },
    ]
  },
  {
    icon: "🛡️",
    name: "Security & Compliance",
    description: "Sicurezza avanzata e conformita normativa per i tuoi clienti.",
    features: [
      { icon: "🔍", title: "Security Intelligence", description: "Eventi, correlazione incidenti, incident actions, MTTR dashboard" },
      { icon: "⚠️", title: "Threat Indicators", description: "Database minacce IP/domain/hash, feed esterni, match automatico asset" },
      { icon: "✅", title: "Compliance", description: "Framework GDPR, ISO 27001, NIS2, audit trail, data retention, report PDF" },
      { icon: "📡", title: "Monitoring", description: "HTTP/ping check, alert automatici, storico uptime, dashboard portale" },
    ]
  },
  {
    icon: "👤",
    name: "Portale Cliente",
    description: "Self-service, trasparenza e soddisfazione per i tuoi clienti.",
    features: [
      { icon: "🌐", title: "Portal v2", description: "Ticket wizard, storico unificato, documenti con firma, pagamenti Stripe" },
      { icon: "❤️", title: "Health Score", description: "Score 0-100 automatico, ranking clienti con trend, alert soglia" },
      { icon: "📊", title: "SLA Analytics", description: "Report mensile PDF, uptime %, benchmark anonimo, alert peggioramento" },
      { icon: "📚", title: "Knowledge Base", description: "Self-service, FAQ automatiche, chatbot AI, suggerimenti da ticket risolti" },
    ]
  },
  {
    icon: "🤖",
    name: "AI & Automazione",
    description: "Intelligenza artificiale e automazioni per lavorare meno e meglio.",
    features: [
      { icon: "🧠", title: "AI Copilot", description: "Suggerimenti proattivi rinnovi/manutenzione, digest giornaliero, sentiment analysis" },
      { icon: "⚡", title: "Automazioni", description: "38+ trigger, 13 azioni, condition builder, dry-run, dashboard analytics" },
      { icon: "🔮", title: "Manutenzione Predittiva", description: "Pattern detection, scoring rischio guasto, interventi preventivi, ROI" },
      { icon: "🗺️", title: "Smart Scheduling", description: "GPS, competenze, carico, SLA, auto-dispatch, ottimizzazione percorso" },
    ]
  },
  {
    icon: "⚙️",
    name: "Piattaforma",
    description: "Personalizzazione, integrazioni e controllo totale.",
    features: [
      { icon: "🏷️", title: "White-label", description: "Dominio custom, branding completo, rimozione riferimenti DeskCore" },
      { icon: "🔌", title: "API Pubblica", description: "REST, OpenAPI, SDK, rate limiting per piano, 17 scope per modulo" },
      { icon: "🛒", title: "Marketplace", description: "16 connettori, 6 categorie: RMM, PSA, Security, Backup, Contabilita, Communication" },
      { icon: "🔑", title: "SSO/SAML", description: "Single sign-on, auto-provisioning utenti, config per tenant" },
    ]
  }
];
---

<PageLayout
  title="Funzionalita — DeskCore"
  description="Scopri i 70+ moduli di DeskCore: ticketing, asset, CRM, fatturazione, security, AI e molto altro."
>
  <!-- Hero -->
  <section class="section features-hero">
    <div class="container">
      <div class="features-hero__content fade-up">
        <h1 class="features-hero__title">Tutto quello che ti serve. Niente di piu.</h1>
        <p class="features-hero__subtitle">
          70+ moduli integrati in un'unica piattaforma. Nessun plugin da comprare, nessuna integrazione da configurare.
          Tutto funziona insieme, out of the box.
        </p>
      </div>
    </div>
  </section>

  <!-- Categories -->
  {categories.map((cat) => (
    <section class="section features-category">
      <div class="container fade-up">
        <div class="features-category__header">
          <span class="features-category__icon">{cat.icon}</span>
          <div>
            <h2 class="features-category__name">{cat.name}</h2>
            <p class="features-category__desc">{cat.description}</p>
          </div>
        </div>

        <div class="features-grid">
          {cat.features.map((f) => (
            <FeatureCard icon={f.icon} title={f.title} description={f.description} />
          ))}
        </div>
      </div>
    </section>
  ))}
</PageLayout>

<style>
  .features-hero {
    text-align: center;
    padding-bottom: 2rem;
  }

  .features-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .features-hero__subtitle {
    font-size: 1.125rem;
    color: var(--gray-600);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.65;
  }

  .features-category {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .features-category__header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .features-category__icon {
    font-size: 2rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .features-category__name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--ink);
    margin-bottom: 0.375rem;
  }

  .features-category__desc {
    font-size: 1rem;
    color: var(--gray-600);
    margin: 0;
    line-height: 1.5;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .features-category__header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
