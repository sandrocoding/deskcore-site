---
import PageLayout from './PageLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<PageLayout title={title} description={description}>
  <div class="docs-wrapper section">
    <div class="container docs-grid">
      <!-- Sidebar (hidden on mobile) -->
      <aside class="docs-sidebar" id="docs-sidebar">
        <DocsSidebar />
      </aside>

      <!-- Mobile sidebar toggle -->
      <button
        class="docs-sidebar-toggle"
        id="docs-sidebar-toggle"
        aria-label="Apri menu documentazione"
        aria-expanded="false"
        aria-controls="docs-sidebar"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" stroke-linecap="round" />
        </svg>
        <span>Menu</span>
      </button>

      <!-- Content -->
      <div class="docs-content">
        <h1 class="docs-title">{title}</h1>
        <div class="prose">
          <slot />
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .docs-grid {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  /* Sidebar */
  .docs-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 2rem);
    width: 240px;
    flex-shrink: 0;
    max-height: calc(100vh - var(--nav-h) - 4rem);
    overflow-y: auto;
    padding-right: 1rem;
    border-right: 1px solid var(--gray-200);
  }

  /* Content */
  .docs-content {
    flex: 1;
    min-width: 0;
  }

  .docs-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .docs-content .prose {
    max-width: 100%;
  }

  /* Mobile toggle */
  .docs-sidebar-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s;
  }

  .docs-sidebar-toggle:hover {
    border-color: var(--accent);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .docs-grid {
      flex-direction: column;
      gap: 0;
    }

    .docs-sidebar {
      display: none;
      position: static;
      width: 100%;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--gray-200);
      padding-right: 0;
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .docs-sidebar.open {
      display: block;
    }

    .docs-sidebar-toggle {
      display: inline-flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('docs-sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');

  toggle?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
    toggle.querySelector('span')!.textContent = isOpen ? 'Chiudi' : 'Menu';
  });
</script>
