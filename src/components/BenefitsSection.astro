---
const benefits = [
  {
    stat: "+30%",
    title: "Ore fatturate",
    description: "Tracciamento automatico di ogni minuto lavorato. Timer integrato, rapportini con un click, nessuna ora persa. I nostri MSP recuperano in media il 30% di ore che prima non venivano registrate."
  },
  {
    stat: "-50%",
    title: "Tempo amministrativo",
    description: "Fatturazione, rapportini e contratti in un click. Workflow automatizzati che eliminano il copia-incolla tra sistemi. Il tuo team torna a fare quello che sa fare: assistenza tecnica."
  },
  {
    stat: "60%",
    title: "Telefonate in meno",
    description: "Il portale cliente self-service cambia le regole del gioco. I clienti vedono lo stato dei ticket, scaricano fatture, consultano la knowledge base. Tu rispondi al telefono solo quando serve davvero."
  },
  {
    stat: "AI",
    title: "Che lavora per te",
    description: "Suggerimenti proattivi su rinnovi e manutenzioni, analisi sentiment dei ticket, report automatici settimanali. L'AI Copilot non sostituisce il tuo team, lo potenzia."
  },
  {
    stat: "48h",
    title: "Setup completo",
    description: "Import CSV per clienti, asset e contratti. Wizard di onboarding guidato passo passo. La maggior parte degli MSP e operativa in 2 giorni, non settimane. Nessun consulente richiesto."
  }
];
---

<section class="section benefits" id="vantaggi">
  <div class="container">
    <div class="benefits__header">
      <h2 class="benefits__title">Perche 200+ MSP scelgono DeskCore</h2>
    </div>

    <div class="benefits__list">
      {benefits.map((b, i) => (
        <div class:list={["benefits__item fade-up", i % 2 !== 0 && "benefits__item--reverse"]}>
          <div class="benefits__text">
            <span class="benefits__stat">{b.stat}</span>
            <h3 class="benefits__item-title">{b.title}</h3>
            <p class="benefits__item-desc">{b.description}</p>
          </div>
          <div class="benefits__visual">
            <span class="benefits__stat-large">{b.stat}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .benefits__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--ink);
  }

  .benefits__list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .benefits__item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .benefits__item--reverse .benefits__visual {
    order: -1;
  }

  .benefits__text {
    display: flex;
    flex-direction: column;
  }

  .benefits__stat {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .benefits__item-title {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .benefits__item-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--gray-600);
  }

  .benefits__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--warm);
    border-radius: var(--radius-lg);
    padding: 3rem;
    min-height: 200px;
  }

  .benefits__stat-large {
    font-family: var(--font-display);
    font-size: 5rem;
    color: var(--accent);
    opacity: 0.12;
    font-weight: 400;
    user-select: none;
  }

  @media (prefers-color-scheme: dark) {
    .benefits__stat-large {
      opacity: 0.2;
    }
  }

  @media (max-width: 768px) {
    .benefits__item,
    .benefits__item--reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .benefits__item--reverse .benefits__visual {
      order: 0;
    }

    .benefits__visual {
      min-height: 120px;
      padding: 2rem;
    }

    .benefits__stat-large {
      font-size: 3.5rem;
    }

    .benefits__title {
      font-size: 2rem;
    }
  }
</style>
