<section class="final-cta">
  <div class="container">
    <div class="final-cta__inner">
      <h2 class="final-cta__title">
        Ogni giorno che aspetti e un giorno di ore non fatturate.
      </h2>
      <p class="final-cta__subtitle">
        Inizia la prova gratuita di 14 giorni. Nessuna carta di credito, nessun vincolo.
      </p>
      <a href="#" class="final-cta__btn">
        Prova DeskCore gratis
        <span class="final-cta__arrow" aria-hidden="true">&rarr;</span>
      </a>
      <p class="final-cta__ps">
        P.S. — Il piano Starter e disponibile per i primi 100 MSP a &euro;29/mese. Dopo, il prezzo salira.
      </p>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 6rem 0;
  }

  .final-cta__inner {
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 5rem 3rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .final-cta__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: #fff;
    margin-bottom: 1.25rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .final-cta__subtitle {
    font-size: 1.125rem;
    line-height: 1.65;
    opacity: 0.9;
    margin-bottom: 2.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .final-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    background: #fff;
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
    margin-bottom: 2rem;
  }

  .final-cta__arrow {
    display: inline-block;
    transition: transform 0.25s var(--ease-out);
    font-size: 1.125rem;
  }

  .final-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: var(--accent-dark);
  }

  .final-cta__btn:hover .final-cta__arrow {
    transform: translateX(4px);
  }

  .final-cta__ps {
    font-size: 0.875rem;
    opacity: 0.75;
    font-style: italic;
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .final-cta__inner {
      padding: 3rem 1.25rem;
      border-radius: var(--radius-md);
    }

    .final-cta__title {
      font-size: 1.875rem;
    }

    .final-cta {
      padding: 4rem 0;
    }
  }
</style>
