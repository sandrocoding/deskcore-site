---
---

<section class="final-cta">
  <div class="container">
    <div class="final-cta__inner scale-in">
      <h2 class="final-cta__title">
        Ogni giorno che aspetti e un giorno di ore perse.
      </h2>
      <p class="final-cta__subtitle">
        Inizia la prova gratuita di 14 giorni. Nessuna carta di credito, nessun vincolo.
      </p>

      <!-- Email capture -->
      <form class="final-cta__form" id="cta-form">
        <input
          type="email"
          class="final-cta__input"
          placeholder="La tua email aziendale"
          required
          aria-label="Email aziendale"
        />
        <button type="submit" class="final-cta__submit">
          Inizia gratis
          <span class="final-cta__arrow" aria-hidden="true">&rarr;</span>
        </button>
      </form>

      <div class="final-cta__trust-row">
        <span class="final-cta__check">&#10003; Nessuna carta richiesta</span>
        <span class="final-cta__check">&#10003; Setup in 5 minuti</span>
        <span class="final-cta__check">&#10003; Cancella quando vuoi</span>
      </div>

      <p class="final-cta__ps">
        P.S. — Il piano Starter e disponibile per i primi 100 MSP a &euro;29/mese. Dopo, il prezzo salira.
      </p>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 6rem 0;
  }

  .final-cta__inner {
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-mid), var(--gradient-end));
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 5rem 3rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .final-cta__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.06;
    pointer-events: none;
  }

  /* Decorative glow orbs */
  .final-cta__inner::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-cta__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: #fff;
    margin-bottom: 1.25rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
  }

  .final-cta__subtitle {
    font-size: 1.125rem;
    line-height: 1.65;
    opacity: 0.9;
    margin-bottom: 2.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
  }

  /* Email form */
  .final-cta__form {
    display: flex;
    gap: 0;
    max-width: 480px;
    margin: 0 auto 1.5rem;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .final-cta__input {
    flex: 1;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.95);
    border: none;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: #1a1a2e;
    outline: none;
  }

  .final-cta__input::placeholder {
    color: #71718f;
  }

  .final-cta__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    background: var(--paper);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9375rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.25s ease;
  }

  .final-cta__submit:hover {
    background: var(--gray-100);
  }

  .final-cta__arrow {
    display: inline-block;
    transition: transform 0.25s var(--ease-out);
    font-size: 1.125rem;
  }

  .final-cta__submit:hover .final-cta__arrow {
    transform: translateX(4px);
  }

  /* Trust row */
  .final-cta__trust-row {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    flex-wrap: wrap;
  }

  .final-cta__check {
    font-size: 0.8125rem;
    opacity: 0.8;
    white-space: nowrap;
  }

  .final-cta__ps {
    font-size: 0.875rem;
    opacity: 0.65;
    font-style: italic;
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.6;
    position: relative;
  }

  @media (max-width: 768px) {
    .final-cta__inner {
      padding: 3rem 1.25rem;
      border-radius: var(--radius-md);
    }

    .final-cta__title {
      font-size: 1.875rem;
    }

    .final-cta {
      padding: 4rem 0;
    }

    .final-cta__form {
      flex-direction: column;
      border-radius: var(--radius-md);
    }

    .final-cta__input {
      border-radius: var(--radius-md) var(--radius-md) 0 0;
    }

    .final-cta__submit {
      border-radius: 0 0 var(--radius-md) var(--radius-md);
      justify-content: center;
    }

    .final-cta__trust-row {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
  }
</style>
