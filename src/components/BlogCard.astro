---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
  readingTime?: string;
}

const { title, description, date, slug, tags, readingTime } = Astro.props;
---

<a class="blog-card card" href={`/blog/${slug}`}>
  <div class="blog-image"></div>
  <div class="blog-body">
    {tags && tags.length > 0 && (
      <div class="blog-tags">
        {tags.map((tag) => (
          <span class="blog-tag badge badge-accent">{tag}</span>
        ))}
      </div>
    )}
    <h3 class="blog-title">{title}</h3>
    <p class="blog-desc">{description}</p>
    <div class="blog-meta">
      <span>{date}</span>
      {readingTime && <span>{readingTime}</span>}
    </div>
  </div>
</a>

<style>
  .blog-card {
    display: block;
    padding: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    color: inherit;
  }

  .blog-image {
    width: 100%;
    height: 200px;
    background: var(--gray-200);
    border-radius: 12px 12px 0 0;
  }

  .blog-body {
    padding: 1.5rem;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .blog-tag {
    font-size: 0.6875rem;
    padding: 0.175rem 0.5rem;
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.25;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .blog-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--gray-600);
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--gray-400);
  }
</style>
