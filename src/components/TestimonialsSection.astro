---
const testimonials = [
  {
    name: "Marco R.",
    role: "Titolare MSP",
    location: "Milano",
    quote: "In 6 mesi abbiamo recuperato il 35% di ore non tracciate. DeskCore si e ripagato dal primo mese.",
    metric: "+35%",
    metricLabel: "ore recuperate"
  },
  {
    name: "Laura B.",
    role: "Operations Manager",
    location: "Roma",
    quote: "Finalmente i clienti non chiamano piu per sapere lo stato dei ticket. Il portale self-service ha cambiato tutto.",
    metric: "-60%",
    metricLabel: "chiamate clienti"
  },
  {
    name: "Andrea G.",
    role: "CTO",
    location: "Torino",
    quote: "L'AI Copilot ci suggerisce rinnovi e manutenzioni prima che ce ne accorgiamo. E come avere un collaboratore in piu.",
    metric: "2x",
    metricLabel: "produttivita"
  }
];
---

<section class="section testimonials" id="testimonianze">
  <div class="container">
    <div class="testimonials__header fade-up">
      <span class="badge badge-accent">Testimonianze</span>
      <h2 class="testimonials__title">Chi lo usa, non torna indietro</h2>
      <p class="testimonials__subtitle">MSP italiani che hanno trasformato il loro business</p>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t, i) => (
        <div class:list={["testimonials__card fade-up", `stagger-${i + 1}`]}>
          <div class="testimonials__metric-badge">
            <span class="testimonials__metric-value">{t.metric}</span>
            <span class="testimonials__metric-label">{t.metricLabel}</span>
          </div>
          <div class="testimonials__quote-mark" aria-hidden="true">&ldquo;</div>
          <blockquote class="testimonials__quote">{t.quote}</blockquote>
          <div class="testimonials__stars" aria-label="5 stelle su 5">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <div class="testimonials__author">
            <span class="testimonials__avatar">{t.name.charAt(0)}</span>
            <div>
              <div class="testimonials__name">
                {t.name}
                <svg class="testimonials__verified" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-label="Verificato">
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                </svg>
              </div>
              <div class="testimonials__role">{t.role} &middot; {t.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .testimonials__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--ink);
    margin-top: 1rem;
    margin-bottom: 0.75rem;
  }

  .testimonials__subtitle {
    font-size: 1.125rem;
    color: var(--gray-600);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonials__card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all 0.35s var(--ease-out);
  }

  .testimonials__card:hover {
    transform: translateY(-4px);
    border-color: rgba(124, 58, 237, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(124, 58, 237, 0.1);
  }

  .testimonials__metric-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(124, 58, 237, 0.08);
    border: 1px solid rgba(124, 58, 237, 0.2);
    border-radius: var(--radius-full);
    margin-bottom: 1.25rem;
    width: fit-content;
  }

  .testimonials__metric-value {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .testimonials__metric-label {
    font-size: 0.75rem;
    color: var(--gray-500);
  }

  .testimonials__quote-mark {
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--accent);
    opacity: 0.2;
    line-height: 1;
    position: absolute;
    top: 4rem;
    right: 1.5rem;
    user-select: none;
  }

  .testimonials__quote {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .testimonials__stars {
    display: flex;
    gap: 0.15rem;
    margin-bottom: 1.25rem;
    font-size: 1rem;
    color: #f59e0b;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--gray-200);
  }

  .testimonials__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9375rem;
    flex-shrink: 0;
  }

  .testimonials__name {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .testimonials__verified {
    color: var(--accent);
    flex-shrink: 0;
  }

  .testimonials__role {
    font-size: 0.8125rem;
    color: var(--gray-400);
  }

  @media (max-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .testimonials__title {
      font-size: 2rem;
    }
  }
</style>
