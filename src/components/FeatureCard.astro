---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

const { icon, title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="feature-card card" {...(href ? { href } : {})}>
  <div class="feature-icon">{icon}</div>
  <h3 class="feature-title">{title}</h3>
  <p class="feature-desc">{description}</p>
  {href && <span class="feature-arrow">&rarr;</span>}
</Tag>

<style>
  .feature-card {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  a.feature-card:hover {
    color: inherit;
  }

  .feature-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-light);
    border-radius: 8px;
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .feature-title {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }

  .feature-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--gray-600);
    margin: 0;
  }

  .feature-arrow {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--accent);
    font-size: 1.125rem;
    transition: transform 0.2s ease;
  }

  .feature-card:hover .feature-arrow {
    transform: translateX(4px);
  }
</style>
