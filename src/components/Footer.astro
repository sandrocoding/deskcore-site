---
const year = new Date().getFullYear();

const prodotto = [
  { href: '/funzionalita', label: 'Funzionalita' },
  { href: '/prezzi', label: 'Prezzi' },
  { href: '/demo', label: 'Demo' },
];

const risorse = [
  { href: '/faq', label: 'FAQ' },
];

const legale = [
  { href: '/privacy', label: 'Privacy' },
  { href: '/termini', label: 'Termini' },
  { href: '/cookie-policy', label: 'Cookie Policy' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo__text"><span class="footer-logo__desk">Desk</span><span class="footer-logo__core">Core</span></span>
          <span class="footer-logo__sub">IT Management Platform</span>
        </a>
        <p class="footer-tagline">Il gestionale IT per MSP italiani.</p>
      </div>

      <!-- Prodotto -->
      <div class="footer-col">
        <h4 class="footer-heading">Prodotto</h4>
        <ul class="footer-list">
          {prodotto.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Risorse -->
      <div class="footer-col">
        <h4 class="footer-heading">Risorse</h4>
        <ul class="footer-list">
          {risorse.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legale -->
      <div class="footer-col">
        <h4 class="footer-heading">Legale</h4>
        <ul class="footer-list">
          {legale.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
        <a href="mailto:info@deskcore.it" class="footer-email">info@deskcore.it</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} DeskCore. Tutti i diritti riservati.</p>
      <span class="footer-italy">
        <svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
          <rect width="6" height="12" fill="#009246"/>
          <rect x="6" width="6" height="12" fill="#fff"/>
          <rect x="12" width="6" height="12" fill="#CE2B37"/>
        </svg>
        Made in Italy
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gray-100);
    border-top: 1px solid var(--gray-200);
    padding: 4rem 0 0;
    margin-top: 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  /* Brand */
  .footer-logo {
    text-decoration: none;
    display: inline-flex;
    flex-direction: column;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  .footer-logo:hover {
    opacity: 0.8;
  }

  .footer-logo__text {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .footer-logo__desk {
    color: var(--gradient-end);
  }

  .footer-logo__core {
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-mid), var(--gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-logo__sub {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-top: 2px;
  }

  .footer-tagline {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.5;
  }

  /* Columns */
  .footer-heading {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    margin-bottom: 1.25rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--gray-600);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--ink);
  }

  .footer-email {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-email:hover {
    color: var(--accent-dark);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--gray-200);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--gray-400);
  }

  .footer-italy {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--gray-400);
  }

  .footer-italy svg {
    border-radius: 2px;
  }

  /* Tablet: 2 columns */
  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 640px) {
    .footer {
      padding: 3rem 0 0;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
      margin-top: 2rem;
    }
  }
</style>
